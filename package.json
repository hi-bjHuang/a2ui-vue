{
  "name": "a2ui-vue",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Vue renderer for A2UI (Agent-to-User Interface)",
  "homepage": "https://a2ui.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hi-bjHuang/a2ui-vue.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./v0_9": {
      "import": {
        "types": "./dist/v0_9/index.d.ts",
        "default": "./dist/v0_9/index.js"
      },
      "require": {
        "types": "./dist/v0_9/index.d.cts",
        "default": "./dist/v0_9/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "npm run typecheck && vite build",
    "dev": "vite build --watch",
    "prepare": "npm run build",
    "typecheck": "vue-tsc --noEmit",
    "demo": "cd a2ui_explorer && vite"
  },
  "dependencies": {
    "@a2ui/markdown-it": "^0.0.4",
    "@a2ui/web_core": "^0.9.2",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "^5.8.0",
    "vite": "^7.3.1",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
